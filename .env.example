# AEGIS-AI Platform - Environment Variables Template
# ⚠️ CRITICAL: Never commit the actual .env file to Git
# This is a TEMPLATE only. Copy to .env.local and fill in actual values
# NEVER share actual .env values via email, Slack, or unencrypted channels

# ============================================================================
# ENVIRONMENT & DEPLOYMENT
# ============================================================================
VITE_ENV=development
NODE_ENV=development

# ============================================================================
# SUPABASE CONFIGURATION
# ⚠️ KEEP THESE SECRETS SAFE - rotate quarterly
# Get from: https://supabase.com/dashboard → Settings → API Keys
# ============================================================================

# Public API Key (Safe for frontend)
# Role: Anonymous user access
# Regenerate: Every 3 months
VITE_SUPABASE_URL=https://[replace-with-your-project].supabase.co
VITE_SUPABASE_KEY=[replace-with-anon-key-from-supabase-dashboard]

# Service Role Key (BACKEND ONLY - NEVER expose to frontend)
# Role: Full database administrative access
# Danger Level: CRITICAL
# Regenerate: Every 3 months
# Store in: GitHub Secrets + Environment Variables only
SUPABASE_SERVICE_ROLE_KEY=[replace-with-service-role-key-from-supabase-dashboard]

# ============================================================================
# ENCRYPTION & SECURITY
# ⚠️ CRITICAL: Generate secure random values
# ============================================================================

# Primary Data Encryption Key (256-bit = 64 hex characters)
# Generate: openssl rand -hex 32
# Or PowerShell: [BitConverter]::ToString([byte[]]((1..32 | ForEach-Object {Get-Random -Maximum 256}))) -replace '-',''
# Regenerate: Every 6 months
ENCRYPTION_KEY=9f3a6b2c4d7e8a1b0c9d5e6f7a8b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b
# Chat Message Encryption Key (256-bit = 64 hex characters)
# Generate: openssl rand -hex 32
# Or PowerShell: [BitConverter]::ToString([byte[]]((1..32 | ForEach-Object {Get-Random -Maximum 256}))) -replace '-',''
# Regenerate: Every 6 months
CHAT_ENCRYPTION_KEY=[replace-with-32-byte-hex-value]

# Data Retention Policy
CHAT_RETENTION_DAYS=90
LOG_RETENTION_DAYS=30

# ============================================================================
# JWT & SESSION MANAGEMENT
# ⚠️ CRITICAL: Generate secure random values for production
# ============================================================================

# JWT Secrets (change for production)
JWT_SECRET=[replace-with-32-byte-secure-random-value]
REFRESH_TOKEN_SECRET=[replace-with-32-byte-secure-random-value]
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Webhook Signature Verification
TELKOM_WEBHOOK_SECRET=[replace-with-webhook-secret-from-telkom]

# Telephony & Provider Integration
TWILIO_ACCOUNT_SID=[replace-with-twilio-account-sid]
TWILIO_AUTH_TOKEN=[replace-with-twilio-auth-token]
TWILIO_PHONE_NUMBER=[replace-with-twilio-sender-number]
TWILIO_WHATSAPP_NUMBER=[replace-with-twilio-whatsapp-enabled-number]
TELKOM_API_KEY=[replace-with-telkom-api-key]
TELKOM_API_URL=https://api.telkom.co.za/ussd/v1
TELKOM_USSD_CODE=[replace-with-approved-ussd-service-code]
BACKEND_PUBLIC_URL=https://your-backend-domain.com
TELKOM_CALLBACK_URL=
ESCALATION_POLICE_CONTACTS=[comma-separated-e164-phone-numbers]
USSD_LOAD_TEST_URL=http://localhost:3000/api/ussd/process
# USSD service-code allowlist — without these the gateway accepts any code.
USSD_SERVICE_CODE=*135*1782#
USSD_ALLOWED_SERVICE_CODES=*135*1782#,*384*30933#,*721#
# ISO country code used to normalise phone numbers in escalation workflows.
COUNTRY_CODE=ZA

# ============================================================================
# REDIS CONFIGURATION (for rate limiting & session management)
# ============================================================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=[replace-with-redis-password-if-needed]

# Alternative single connection-string form (used by server/utils/cacheManager.ts
# and the notification queue). Takes precedence over REDIS_HOST/PORT when set.
REDIS_URL=
# Set to "true" if the Redis provider requires TLS (rediss://).
REDIS_TLS=false
# Redis is skipped in development by default; set to "true" to force a real
# connection locally.
REDIS_FORCE_CONNECT=false

# ============================================================================
# DATABASE CONFIGURATION (for connection pooling)
# ============================================================================

DB_HOST=localhost
DB_PORT=5432
DB_NAME=aegis_db
DB_USER=aegis_user
DB_PASSWORD=[replace-with-database-password]

# Connection Pool Settings
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=2000

# Optional read replica (falls back to the primary pool when unset)
DB_REPLICA_HOST=
DB_REPLICA_PORT=5432
DB_REPLICA_POOL_MAX=30

# ============================================================================
# TLS/SSL CONFIGURATION (for HTTPS)
# ============================================================================

# SSL Certificate Paths (only needed for production)
SSL_CERT_PATH=[replace-with-path-to-ssl-cert.pem]
SSL_KEY_PATH=[replace-with-path-to-ssl-key.pem]

# CSP Report URI for security violations
CSP_REPORT_URI=https://aegis-ai.co.za/api/csp-report

# ============================================================================
# API GATEWAY CONFIGURATION
# ============================================================================

# Frontend API Endpoint (fixed public backend host, routes through API gateway)
VITE_API_URL=https://your-backend-domain.com/api

# Where survivors get the dedicated mobile app (shown on the web portal when a
# survivor signs in, since the web app is for professional roles only).
# e.g. a Play Store / App Store / install-instructions URL. Optional.
VITE_MOBILE_APP_URL=

# API Server Configuration
PORT=3000
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:8080

# Public backend URL — used to build absolute links in outbound notifications
# (SMS/WhatsApp/email) and defaults to BACKEND_PUBLIC_URL above if unset.
APP_BASE_URL=https://your-backend-domain.com
# Public frontend URL — used in notification links that should open the web app.
FRONTEND_URL=https://your-frontend-domain.com
# Comma-separated list of this API's own instance URLs, used by the load
# balancer / multi-instance health checks. Leave unset for a single instance.
INSTANCE_URLS=

# Rate Limiting (Server-side)
RATE_LIMIT_WINDOW_SECONDS=900
RATE_LIMIT_MAX_REQUESTS=50
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# MONITORING & OBSERVABILITY
# ⚠️ Setup DataDog account before populating
# ============================================================================

# DataDog Configuration
DATADOG_ENABLED=true
DATADOG_AGENT_HOST=localhost
DATADOG_AGENT_PORT=8125
DATADOG_ENV=development
DATADOG_SERVICE=aegis-api
DATADOG_VERSION=1.0.0
DATADOG_METRIC_PREFIX=aegis
# Deployment region tag attached to Datadog metrics (server-side).
DEPLOYMENT_REGION=af-south-1

# Datadog Frontend (RUM & Logs)
VITE_DATADOG_ENABLED=true
VITE_DATADOG_APPLICATION_ID=[replace-with-datadog-app-id]
VITE_DATADOG_CLIENT_TOKEN=[replace-with-datadog-client-token]
VITE_DATADOG_SERVICE=aegis-web
VITE_DATADOG_ENV=development
VITE_DATADOG_VERSION=1.0.0

# Application Performance Monitoring
VITE_APM_ENABLED=true
VITE_TRACE_SAMPLE_RATE=1.0

# ============================================================================
# SOUTH AFRICA DEPLOYMENT CONFIGURATION
# ============================================================================

VITE_DEPLOYMENT_REGION=af-south-1
VITE_COUNTRY_CODE=ZA

# National / regional crisis line (survivor Personal Dashboard & tel: links). Defaults: 0800 428 428 (ZA GBV crisis line).
# VITE_CRISIS_LINE_DISPLAY=0800 428 428
# VITE_CRISIS_LINE_TEL=tel:0800428428

VITE_COMPLIANCE_FRAMEWORK=POPIA
VITE_DATA_RESIDENCY_REQUIRED=true

# South Africa Domain & Infrastructure
VITE_PRIMARY_DOMAIN=aegis-ai.co.za
VITE_SA_REGION_PRIMARY=af-south-1
VITE_SA_REGION_SECONDARY=af-south-2

# ============================================================================
# POPIA COMPLIANCE
# ============================================================================

# Register at: https://www.justice.gov.za/inforeg/
VITE_POPIA_REGISTRATION_ID=[replace-with-irsa-registration-id]
VITE_POPIA_INFORMATION_OFFICER_EMAIL=compliance@aegis-ai.co.za
VITE_POPIA_DPA_SIGNED=true

# Data Protection Officer (Required under POPIA)
VITE_DPO_NAME=[replace-with-dpo-full-name]
VITE_DPO_EMAIL=dpo@aegis-ai.co.za
VITE_DPO_PHONE=[replace-with-dpo-phone]

# ============================================================================
# LOCALIZATION & ACCESSIBILITY
# ============================================================================

# Language Configuration
VITE_DEFAULT_LANGUAGE=en
VITE_SUPPORTED_LANGUAGES=en,sw,fr,am,yo,ha,zu,af,xh,st,tn,ts,ve,nso,nr,ss
VITE_LANGUAGE_DETECTION=true
VITE_FALLBACK_LANGUAGE=en

# Accessibility Standards
VITE_WCAG_COMPLIANCE_LEVEL=2.1 AA
VITE_ACCESSIBILITY_TESTING=true
VITE_HIGH_CONTRAST_MODE=true

# ============================================================================
# NATIONAL FRAMEWORKS ALIGNMENT
# ============================================================================

VITE_DSD_ALIGNMENT=true
VITE_NDOH_ALIGNMENT=true
VITE_POPIA_ALIGNMENT=true

# ============================================================================
# COMPLIANCE MONITORING & AUDITS
# ============================================================================

VITE_COMPLIANCE_METRICS_ENABLED=true
VITE_POPIA_AUDIT_FREQUENCY=quarterly
VITE_SECURITY_AUDIT_FREQUENCY=quarterly
VITE_DATA_QUALITY_AUDIT_FREQUENCY=monthly

# Health & Safety Standards (NDoH)
VITE_HEALTH_SERVICE_STANDARDS=true
VITE_SURVIVOR_CARE_STANDARDS=true
VITE_DATA_BACKUP_FREQUENCY=daily
VITE_DISASTER_RECOVERY_TEST_FREQUENCY=quarterly

# ============================================================================
# HUGGINGFACE AI INFERENCE API
# Free tier available at: https://huggingface.co/settings/tokens
# Used for: ML-based NLP severity scoring (riskScoring.ts) AND the survivor
# support chat (/api/ai/survivor-chat) via the OpenAI-compatible HF router.
# ============================================================================
HUGGINGFACE_API_TOKEN=[replace-with-hf-read-token]
# Chat model served through the HF router (any instruct/chat model works).
HUGGINGFACE_CHAT_MODEL=meta-llama/Llama-3.1-8B-Instruct
# Speech-to-text model for the mobile voice incident report.
HUGGINGFACE_ASR_MODEL=openai/whisper-large-v3
# In-process (Xenova/transformers.js) sentiment model used as a fallback for
# risk scoring when HUGGINGFACE_API_TOKEN is unset or the HF API is unreachable.
XENOVA_SENTIMENT_MODEL=Xenova/distilbert-base-uncased-finetuned-sst-2-english

# Anthropic (Claude) — used for the WhatsApp AI assistant, with a structured
# menu fallback when unavailable. Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=[replace-with-anthropic-api-key]

# WhatsApp Business API (Meta)
# Get from: https://developers.facebook.com/apps/ → WhatsApp → Getting Started
WHATSAPP_VERIFY_TOKEN=[replace-with-your-webhook-verify-token]
WHATSAPP_ACCESS_TOKEN=[replace-with-whatsapp-business-access-token]
WHATSAPP_PHONE_NUMBER_ID=[replace-with-whatsapp-phone-number-id]
# Webhook payload signature verification (X-Hub-Signature-256).
WHATSAPP_APP_SECRET=[replace-with-whatsapp-app-secret]

# ============================================================================
# EMAIL NOTIFICATIONS (optional — Resend)
# ============================================================================
RESEND_API_KEY=[optional-resend-api-key]
EMAIL_FROM=notifications@aegis-ai.co.za

# ============================================================================
# AZURE SPEECH (optional — text-to-speech for voice outputs)
# ============================================================================
AZURE_SPEECH_KEY=[optional-azure-speech-key]
AZURE_SPEECH_REGION=[optional-azure-region-e.g.-southafricanorth]

# ============================================================================
# FEATURE FLAGS
# ============================================================================

VITE_FEATURE_ENABLE_ENCRYPTION=true
VITE_FEATURE_ENABLE_AUDIT_LOGGING=true
VITE_FEATURE_ENABLE_PERFORMANCE_MONITORING=true
VITE_FEATURE_ENABLE_COMPLIANCE_REPORTING=true

# ============================================================================
# LOGGING & MONITORING
# ============================================================================

LOG_LEVEL=info
SENTRY_DSN=[optional-sentry-dsn-for-error-tracking]
DATADOG_API_KEY=[optional-datadog-api-key]
NEW_RELIC_LICENSE_KEY=[optional-new-relic-key]

# Prometheus /metrics endpoint protection (choose one):
# Option A — Bearer token (preferred for cloud deployments behind load balancers)
METRICS_TOKEN=[replace-with-secure-random-token]
# Option B — IP allowlist (comma-separated, used only when METRICS_TOKEN is unset)
# METRICS_ALLOWED_IPS=127.0.0.1,::1,10.0.0.0/8

# ============================================================================
# AUDIT, AUTH CACHE, NOTIFICATION WORKER
# ============================================================================
# Periodic audit-chain integrity verification.
#  - Default: enabled in production, disabled otherwise.
#  - Override with true/false.
AUDIT_CHAIN_CRON_ENABLED=true
# Interval between audit-chain verifications in milliseconds (default 6h).
AUDIT_CHAIN_CRON_INTERVAL_MS=21600000

# Auth cache TTL (seconds). Used by both REST and WebSocket auth caches.
# Lower = faster revocation, higher = fewer Supabase calls.
AUTH_CACHE_TTL_SECONDS=60

# Notification worker:
#  - Set to "false" on every API replica.
#  - Set to "true" on the dedicated worker deployment (single replica).
NOTIFICATION_WORKER_ENABLED=false
NOTIFICATION_WORKER_INTERVAL_MS=15000
NOTIFICATION_WORKER_BATCH_SIZE=25

# BullMQ notification queue (server/queue/notificationQueue.ts) — only used
# when REDIS_URL/REDIS_HOST is configured. Raise these during a crisis-driven
# SMS/alert spike without a redeploy.
NOTIFICATION_QUEUE_CONCURRENCY=10
NOTIFICATION_QUEUE_RATE_LIMIT_MAX=100
NOTIFICATION_QUEUE_RATE_LIMIT_DURATION_MS=60000

# Optional Expo access token for higher push-notification rate limits.
# Push delivery works without it; set on the worker deployment if you have one.
EXPO_ACCESS_TOKEN=

# ============================================================================
# DEVELOPMENT TOOLS (Not for production)
# ============================================================================

VITE_DEBUG_MODE=false
VITE_LOG_LEVEL=info

# ============================================================================
# SECURITY CHECKLIST
# ============================================================================
# Before deploying to production:
# ☑ Rotate all secrets (Supabase keys, encryption keys)
# ☑ Verify .gitignore prevents .env from being committed
# ☑ Store secrets in GitHub Secrets, not in .env file
# ☑ Enable HTTPS/TLS for all communications
# ☑ Verify rate limiting is enforced server-side
# ☑ Confirm API Gateway is in place (not direct Supabase access)
# ☑ Check encryption is enabled for sensitive data
# ☑ Verify monitoring/DataDog is connected
# ☑ Confirm POPIA compliance registration
# ☑ Get security team sign-off
# ============================================================================

# ============================================================================
# SEED SCRIPT (scripts/seed-data/seed.ts)
# ============================================================================
# Passwords for the demo accounts created by `npm run seed`. If unset, a
# random password is generated and printed once when the script runs.
# Minimum 12 characters.
SEED_ADMIN_PASSWORD=
SEED_POLICE_PASSWORD=
SEED_NGO_PASSWORD=
SEED_ANALYST_PASSWORD=
SEED_COUNSELOR_PASSWORD=

# ============================================================================
# ADMIN DASHBOARD THRESHOLDS (optional — sane defaults if unset)
# ============================================================================
ADMIN_ALERTS_REFRESH_MS=15000
ADMIN_AUDIT_REFRESH_MS=30000
ADMIN_METRICS_REFRESH_MS=30000
ADMIN_PENDING_APPROVALS_WARNING=5
ADMIN_PENDING_DELETION_REQUESTS_WARNING=3
ADMIN_SECURITY_POSTURE_MINIMUM=70
ADMIN_UNRESOLVED_ESCALATIONS_WARNING=3

# ============================================================================
# LOCAL / QA SCRIPTS (not needed for the running app — only for scripts/*)
# ============================================================================
# scripts/test-ussd-local.cjs
AEGIS_USSD_TEST_URL=http://localhost:3000/api/ussd
AEGIS_USSD_LANG=en
# scripts/qa-analyst-seams.mjs
QA_ANALYST_EMAIL=
QA_ANALYST_PASSWORD=
# scripts/qa-sync-e2e.mjs (cross-app web<->mobile sync probe)
QA_POLICE_PASSWORD=
