{
  "expo": {
    "name": "AEGIS Support",
    "slug": "aegis-survivor-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "aegis",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#070D17",
    "newArchEnabled": false,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "ios": {
      "bundleIdentifier": "com.aegisai.survivor",
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Your location is shared only when you send an emergency SOS, so responders can reach you.",
        "NSFaceIDUsageDescription": "Use Face ID to unlock the app and keep your information private."
      }
    },
    "android": {
      "package": "com.aegisai.survivor",
      "adaptiveIcon": {
        "backgroundColor": "#070D17",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Your location is shared only when you send an emergency SOS, so responders can reach you."
        }
      ],
      "expo-localization",
      "expo-font",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow AEGIS to record a voice note so you can describe an incident by speaking."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow AEGIS to attach photos as evidence to your case."
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e5226782-ed53-4e3d-b2c1-1ee49325d68e"
      }
    }
  }
}
