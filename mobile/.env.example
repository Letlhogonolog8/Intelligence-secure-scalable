# Expo public env vars (inlined into the app bundle — use only publishable values)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=sb_publishable_xxx
# Backend base URL (no trailing /api). For local dev use http://<your-lan-ip>:5000
EXPO_PUBLIC_API_URL=https://aegis-backend-zhv3.onrender.com
# Professional web portal (staff sign in here; shares the same backend)
EXPO_PUBLIC_WEB_PORTAL_URL=https://aegis-ai-platform.vercel.app
