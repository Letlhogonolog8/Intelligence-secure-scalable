{
  "name": "vite_react_shadcn_ts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:server": "tsx watch server/index.ts",
    "dev:worker": "tsx watch server/worker.ts",
    "dev:client": "vite",
    "dev:ussd": "concurrently \"npm run dev:server\" \"ngrok http 3001\"",
    "dev:all": "concurrently \"npm run dev:server\" \"npm run dev:client\" \"ngrok http 3001\"",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "build:server": "tsc --project tsconfig.server.json && node -e \"const fs=require('fs');fs.mkdirSync('dist/server',{recursive:true});fs.writeFileSync('dist/server/package.json','{\\\"type\\\":\\\"commonjs\\\"}')\"",
    "build:all": "npm run build:server && npm run build",
    "start": "node dist/server/index.js",
    "start:worker": "node dist/server/worker.js",
    "lint": "eslint .",
    "typecheck": "tsc -b tsconfig.json && tsc -p tsconfig.server.json",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "node -e \"const fs=require('fs');const cp=require('child_process');const shouldInstall=process.env.NODE_ENV!=='production'&&process.env.CI!=='true'&&process.env.HUSKY!=='0'&&fs.existsSync('.git');if(shouldInstall){try{cp.execSync('husky install',{stdio:'ignore'})}catch{}}\"",
    "pre-commit": "lint-staged && npm run typecheck",
    "seed": "tsx scripts/seed-data/seed.ts",
    "seed:clear": "tsx scripts/seed-data/seed.ts --clear",
    "ussd:at": "node test-at-ussd.js",
    "db:migrate": "echo 'Run migration in Supabase Dashboard or use supabase CLI'",
    "db:status": "echo 'Check Supabase Dashboard for database status'",
    "deploy:function": "echo 'Run: supabase functions deploy aegis-survivor-chat'",
    "setup": "npm install && echo 'Next: Configure .env and run database migrations'"
  },
